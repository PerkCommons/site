# Public build-time browser values.
PUBLIC_TURNSTILE_SITE_KEY=

# Public browser credentials. Row Level Security must remain enabled.
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Worker runtime values. Store secrets with `wrangler secret put <NAME>`.
SUPABASE_PUBLISHABLE_KEY=
TURNSTILE_SECRET_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUBMISSION_FINGERPRINT_SECRET=
GITHUB_DATA_PUBLICATION_TOKEN=
GITHUB_SITE_DEPLOY_TOKEN=
