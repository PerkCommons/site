# Public Turnstile site key. Use Cloudflare's test key locally.
PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Public browser credentials. Row Level Security must remain enabled.
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Worker secrets: set with `wrangler pages secret put <NAME>`.
TURNSTILE_SECRET_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
