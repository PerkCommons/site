{
  "name": "@perkcommons/site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "dev:worker": "npm run build && wrangler dev",
    "fetch:data": "node scripts/fetch-data.mjs",
    "sync:taxonomy": "node scripts/sync-taxonomy.mjs",
    "prebuild": "npm run fetch:data",
    "build": "astro check && astro build && pagefind --site dist",
    "preview": "astro preview",
    "check": "node scripts/sync-taxonomy.mjs --check && astro check && tsc --noEmit && tsc -p worker/tsconfig.json --noEmit && tsc -p worker/tests/tsconfig.json --noEmit",
    "test": "npm run check && npm run test:unit",
    "test:unit": "tsx --test tests/unit/*.test.ts worker/tests/*.test.ts",
    "test:browser": "playwright test"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@supabase/supabase-js": "^2.110.7",
    "@tailwindcss/vite": "^4.3.3",
    "astro": "^7.1.0",
    "lucide-astro": "^0.556.0",
    "tailwindcss": "^4.3.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@cloudflare/workers-types": "^5.20260716.1",
    "@playwright/test": "^1.61.1",
    "pagefind": "^1.5.2",
    "tsx": "^4.23.1",
    "typescript": "^6.0.0",
    "wrangler": "^4.111.0"
  }
}
