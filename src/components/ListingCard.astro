---
import { ArrowUpRight, CheckCircle2, Star } from "lucide-astro";
import { categories, formatDate, statusLabel, type Listing } from "../lib/listings";
import { subcategoryLabel } from "../lib/taxonomy";
const { listing } = Astro.props as { listing: Listing };
---
<article class="listing-card group flex h-full flex-col border-t border-line py-6" data-category={listing.category} data-listing-id={listing.id}>
  <div class="flex flex-wrap items-center gap-2 text-xs font-medium">
    <span class="rounded px-2 py-1 status-{listing.status}">{statusLabel(listing.status)}</span>
    <a href={`/categories/${listing.category}/`} class="text-muted">{categories[listing.category]}</a>
    {listing.sponsor && <span class="rounded border border-line px-2 py-1 text-muted">Sponsored</span>}
  </div>
  <p class="mt-5 text-sm font-medium text-muted">{listing.provider}</p>
  <h2 class="mt-1 flex items-start gap-2 text-xl font-semibold leading-7 text-ink"><a href={`/opportunities/${listing.id}/`} class="decoration-line group-hover:underline">{listing.title}</a><span data-feature-star={listing.id} class="hidden shrink-0 text-amber-500" aria-label="Featured opportunity" title="Featured opportunity"><Star size={19} fill="currentColor" aria-hidden="true" /></span></h2>
  <p class="mt-3 line-clamp-3 text-sm leading-6 text-muted">{listing.description}</p>
  {listing.subcategories.length > 0 && <p class="mt-3 text-xs leading-5 text-muted">{listing.subcategories.slice(0, 2).map((item) => subcategoryLabel(listing.category, item)).join(" · ")}</p>}
  <p class="mt-4 text-sm font-medium text-ink">{listing.value}</p>
  <div class="mt-auto flex items-center justify-between gap-4 pt-6 text-xs text-muted">
    <span class="inline-flex items-center gap-1.5"><CheckCircle2 size={14} /> Source checked {formatDate(listing.reviewDate)}</span>
    <a href={`/opportunities/${listing.id}/`} aria-label={`View ${listing.title}`} class="text-ink"><ArrowUpRight size={18} /></a>
  </div>
</article>
