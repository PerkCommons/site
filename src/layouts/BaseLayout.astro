---
import { Github, Menu, Moon, ShieldCheck, Sun, X } from "lucide-astro";
import "../styles/global.css";

interface Props { title: string; description: string; noindex?: boolean; }
const { title, description, noindex = false } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow, noarchive" />}
    <meta name="theme-color" content="#FAFBFC" />
    <script is:inline>
      (() => {
        let saved = null;
        try {
          saved = localStorage.getItem("perkcommons-theme");
        } catch {}
        const theme = saved === "dark" || saved === "light"
          ? saved
          : matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light";
        document.documentElement.dataset.theme = theme;
        document
          .querySelector('meta[name="theme-color"]')
          ?.setAttribute("content", theme === "dark" ? "#0D1117" : "#FAFBFC");
      })();
    </script>
    <link rel="icon" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <title>{title}</title>
    <slot name="head" />
  </head>
  <body>
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:bg-surface focus:px-4 focus:py-3">Skip to content</a>
    <header class="border-b border-line bg-surface">
      <div class="container flex min-h-16 items-center justify-between gap-4">
        <a href="/" class="flex items-center gap-2.5 no-underline" aria-label="PerkCommons home">
          <span class="brand-mark grid size-8 place-items-center rounded-md text-sm font-bold text-white">P</span>
          <span class="text-base font-semibold text-ink">PerkCommons</span>
        </a>
        <nav class="hidden items-center gap-7 text-sm font-medium text-muted md:flex" aria-label="Primary navigation">
          <a href="/opportunities/" class="hover:text-ink">Browse</a>
          <a href="/categories/" class="hover:text-ink">Categories</a>
          <a href="/about/" class="hover:text-ink">How it works</a>
          <a href="https://github.com/PerkCommons/data" class="hover:text-ink">Open data</a>
          <a href="https://github.com/PerkCommons" class="inline-flex items-center gap-1.5 hover:text-ink"><Github size={16} /> GitHub</a>
          <a href="/moderator-login/" class="grid size-11 place-items-center rounded-md border border-line text-ink" aria-label="Moderator sign in" title="Moderator sign in"><ShieldCheck size={19} aria-hidden="true" /></a>
          <a href="/submit/" class="rounded-md bg-action px-4 py-2.5 text-white hover:bg-action-hover">Submit an opportunity</a>
        </nav>
        <button id="menu-button" class="grid size-10 place-items-center rounded-md border border-line md:hidden" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu"><Menu id="menu-open" size={20} /><X id="menu-close" class="hidden" size={20} /></button>
      </div>
      <nav id="mobile-menu" class="container hidden border-t border-line py-3 md:hidden" aria-label="Mobile navigation">
        <a class="block py-3" href="/opportunities/">Browse</a><a class="block py-3" href="/categories/">Categories</a><a class="block py-3" href="/about/">How it works</a><a class="block py-3" href="https://github.com/PerkCommons/data">Open data</a><a class="flex min-h-11 items-center gap-2 py-3" href="/moderator-login/"><ShieldCheck size={18} aria-hidden="true" /> Moderator sign in</a><a class="block py-3" href="/submit/">Submit an opportunity</a>
      </nav>
    </header>
    <main id="main"><slot /></main>
    <footer class="mt-20 border-t border-line bg-surface py-12 text-sm text-muted">
      <div class="container grid gap-8 sm:grid-cols-2 lg:grid-cols-[1.4fr_.8fr_.9fr_1.3fr]">
        <div><p class="font-semibold text-ink">PerkCommons</p><p class="mt-2 max-w-md leading-6">An open, community-maintained index of credible opportunities. Free to browse and reuse.</p></div>
        <div><p class="font-semibold text-ink">Project</p><a class="mt-3 block" href="/about/">About</a><a class="mt-2 block" href="https://github.com/PerkCommons/docs">Policies</a><a class="mt-2 block" href="https://github.com/PerkCommons/data">Dataset</a></div>
        <div><p class="font-semibold text-ink">Participate</p><a class="mt-3 block" href="/submit/">Submit</a><a class="mt-2 block" href="https://github.com/PerkCommons/data/issues">Report a correction</a><a class="mt-2 inline-flex items-center gap-1.5" href="/moderator-login/"><ShieldCheck size={15} aria-hidden="true" /> Moderator sign in</a></div>
        <div aria-label="Contact">
          <p class="font-semibold text-ink">Contact</p>
          <a class="mt-3 block" href="mailto:hello@perkcommons.com">General</a>
          <a class="mt-2 block" href="mailto:support@perkcommons.com">Support</a>
          <a class="mt-2 block" href="mailto:security@perkcommons.com">Security</a>
          <a class="mt-2 block" href="mailto:privacy@perkcommons.com">Privacy</a>
          <a class="mt-2 block" href="mailto:press@perkcommons.com">Press</a>
        </div>
      </div>
    </footer>
    <button
      id="theme-toggle"
      class="theme-toggle"
      type="button"
      aria-label="Switch color theme"
      title="Switch color theme"
    >
      <Moon class="theme-icon theme-icon-moon" size={20} aria-hidden="true" />
      <Sun class="theme-icon theme-icon-sun" size={20} aria-hidden="true" />
    </button>
    <script>
      const button = document.querySelector<HTMLButtonElement>("#menu-button");
      const menu = document.querySelector<HTMLElement>("#mobile-menu");
      button?.addEventListener("click", () => {
        const open = button.getAttribute("aria-expanded") === "true";
        button.setAttribute("aria-expanded", String(!open));
        button.setAttribute("aria-label", open ? "Open menu" : "Close menu");
        menu?.classList.toggle("hidden", open);
        document.querySelector("#menu-open")?.classList.toggle("hidden", !open);
        document.querySelector("#menu-close")?.classList.toggle("hidden", open);
      });

      const themeToggle = document.querySelector<HTMLButtonElement>("#theme-toggle");
      const root = document.documentElement;
      const colorScheme = matchMedia("(prefers-color-scheme: dark)");
      const updateThemeControl = () => {
        const dark = root.dataset.theme === "dark";
        const label = dark ? "Switch to light mode" : "Switch to dark mode";
        themeToggle?.setAttribute("aria-label", label);
        themeToggle?.setAttribute("title", label);
        themeToggle?.setAttribute("aria-pressed", String(dark));
        document
          .querySelector<HTMLMetaElement>('meta[name="theme-color"]')
          ?.setAttribute("content", dark ? "#0D1117" : "#FAFBFC");
      };
      const applyTheme = (theme: "light" | "dark", persist: boolean) => {
        root.classList.add("theme-transitioning");
        root.dataset.theme = theme;
        if (persist) {
          try {
            localStorage.setItem("perkcommons-theme", theme);
          } catch {}
        }
        updateThemeControl();
        window.setTimeout(
          () => root.classList.remove("theme-transitioning"),
          280,
        );
      };

      updateThemeControl();
      themeToggle?.addEventListener("click", () => {
        applyTheme(root.dataset.theme === "dark" ? "light" : "dark", true);
      });
      colorScheme.addEventListener("change", (event) => {
        let saved = null;
        try {
          saved = localStorage.getItem("perkcommons-theme");
        } catch {}
        if (!saved)
          applyTheme(event.matches ? "dark" : "light", false);
      });

      const listingNodes = [
        ...document.querySelectorAll<HTMLElement>("[data-listing-id]"),
      ];
      if (listingNodes.length) {
        void fetch("/api/listings/state")
          .then(async (response) => {
            if (!response.ok) return;
            const payload = (await response.json()) as {
              listings?: Array<{
                listing_id: string;
                featured: boolean;
                removed: boolean;
              }>;
            };
            const states = new Map(
              (payload.listings ?? []).map((item) => [item.listing_id, item]),
            );
            listingNodes.forEach((node) => {
              const id = node.dataset.listingId;
              if (!id) return;
              const state = states.get(id);
              if (state?.removed) {
                if (node.hasAttribute("data-listing-detail")) {
                  node.replaceChildren();
                  const notice = document.createElement("section");
                  notice.className = "py-16 text-center";
                  const heading = document.createElement("h1");
                  heading.className = "text-3xl font-semibold";
                  heading.textContent = "Listing removed";
                  const detail = document.createElement("p");
                  detail.className = "mt-3 text-muted";
                  detail.textContent =
                    "This opportunity was removed after moderator review.";
                  const back = document.createElement("a");
                  back.href = "/opportunities/";
                  back.className = "mt-6 inline-flex font-medium";
                  back.textContent = "Browse other opportunities";
                  notice.append(heading, detail, back);
                  node.append(notice);
                } else node.hidden = true;
              }
              document
                .querySelectorAll<HTMLElement>(`[data-feature-star="${CSS.escape(id)}"]`)
                .forEach((star) => star.classList.toggle("hidden", !state?.featured));
            });

            const toggle = document.querySelector<HTMLButtonElement>(
              "[data-feature-toggle]",
            );
            if (!toggle?.dataset.featureToggle) return;
            const auth = await fetch("/api/auth/me");
            if (!auth.ok) return;
            const id = toggle.dataset.featureToggle;
            let featured = states.get(id)?.featured ?? false;
            const featureStatus = document.querySelector<HTMLElement>(
              "[data-feature-status]",
            );
            const updateToggle = () => {
              toggle.setAttribute("aria-pressed", String(featured));
              toggle.querySelector("span")!.textContent = featured
                ? "Remove featured status"
                : "Feature opportunity";
              toggle.classList.remove("hidden");
              toggle.classList.add("inline-flex");
            };
            updateToggle();
            toggle.addEventListener("click", async () => {
              toggle.disabled = true;
              try {
                const response = await fetch(
                  `/api/moderation/listings/${encodeURIComponent(id)}/feature`,
                  {
                    method: "POST",
                    headers: { "content-type": "application/json" },
                    body: JSON.stringify({ featured: !featured }),
                  },
                );
                if (!response.ok) {
                  if (featureStatus)
                    featureStatus.textContent = "Featured status could not be updated.";
                  return;
                }
                featured = !featured;
                document
                  .querySelectorAll<HTMLElement>(`[data-feature-star="${CSS.escape(id)}"]`)
                  .forEach((star) => star.classList.toggle("hidden", !featured));
                updateToggle();
                if (featureStatus)
                  featureStatus.textContent = featured
                    ? "Opportunity marked as featured."
                    : "Featured status removed.";
              } finally {
                toggle.disabled = false;
              }
            });
          })
          .catch(() => undefined);
      }
    </script>
  </body>
</html>
