---
import { ArrowRight } from "lucide-astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getListings } from "../../lib/listings";
import { categoryDefinitions } from "../../lib/taxonomy";

const listings = await getListings();
const counts = new Map<string, number>();
for (const listing of listings) {
  counts.set(listing.category, (counts.get(listing.category) ?? 0) + 1);
}
---

<BaseLayout title="Opportunity categories — PerkCommons" description="Understand and browse the categories used by the open PerkCommons opportunity index.">
  <section class="container py-14">
    <p class="text-sm font-semibold text-brand">Taxonomy</p>
    <h1 class="mt-2 text-4xl font-semibold">Opportunity categories</h1>
    <p class="mt-4 max-w-2xl leading-7 text-muted">Categories describe what an opportunity is. Eligibility on each record explains who can access it.</p>
    <div class="mt-10 grid gap-x-10 md:grid-cols-2">
      {categoryDefinitions.map((category) => {
        const count = counts.get(category.id) ?? 0;
        return (
          <article class="border-t border-line py-6">
            <div class="flex items-start justify-between gap-4">
              <div>
                <h2 class="text-xl font-semibold">{category.label}</h2>
                <p class="mt-2 max-w-xl text-sm leading-6 text-muted">{category.description}</p>
              </div>
              <span class="shrink-0 text-sm text-muted">{count}</span>
            </div>
            {count > 0 ? (
              <a href={`/categories/${category.id}/`} class="mt-4 inline-flex min-h-11 items-center gap-2 text-sm font-medium">Browse {count === 1 ? "opportunity" : "opportunities"} <ArrowRight size={16} /></a>
            ) : (
              <p class="mt-4 text-sm text-muted">No published opportunities yet.</p>
            )}
          </article>
        );
      })}
    </div>
  </section>
</BaseLayout>
