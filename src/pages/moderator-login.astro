---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Moderator sign in - PerkCommons"
  description="Sign in to the private PerkCommons moderation workspace."
  noindex
>
  <section class="container py-14 sm:py-20">
    <div class="mx-auto max-w-md">
      <p class="text-sm font-semibold text-brand">Private workspace</p>
      <h1 class="mt-2 text-3xl font-semibold">Moderator sign in</h1>
      <p class="mt-3 leading-7 text-muted">
        Only active PerkCommons moderators can continue.
      </p>
      <form
        id="login-form"
        method="post"
        action="/api/auth/session"
        class="mt-8 space-y-5 rounded-md border border-line bg-white p-5 sm:p-7"
      >
        <label class="block"
          ><span class="text-sm font-medium">Email</span><input
            required
            type="email"
            name="email"
            autocomplete="username"
            class="mt-2 min-h-11 w-full rounded-md border border-line px-3"
          /></label
        >
        <label class="block"
          ><span class="text-sm font-medium">Password</span><input
            required
            type="password"
            name="password"
            autocomplete="current-password"
            class="mt-2 min-h-11 w-full rounded-md border border-line px-3"
          /></label
        >
        <button
          type="submit"
          class="min-h-11 w-full rounded-md bg-ink px-4 font-medium text-white disabled:opacity-60"
          >Sign in</button
        >
        <p
          id="login-status"
          role="status"
          aria-live="polite"
          class="text-sm text-muted"
        >
        </p>
      </form>
    </div>
  </section>

  <script>
    import { getSupabase } from "../lib/supabase";
    const form = document.querySelector<HTMLFormElement>("#login-form");
    const status = document.querySelector<HTMLElement>("#login-status");
    form?.addEventListener("submit", async (event) => {
      event.preventDefault();
      if (!form.reportValidity()) return;
      const button = form.querySelector<HTMLButtonElement>(
        "button[type=submit]",
      );
      const data = new FormData(form);
      if (button) button.disabled = true;
      if (status) status.textContent = "Signing in...";
      let supabase;
      try {
        supabase = getSupabase();
      } catch {
        if (status)
          status.textContent =
            "Sign-in is temporarily unavailable. Please try again later.";
        if (button) button.disabled = false;
        return;
      }
      const { data: auth, error } = await supabase.auth.signInWithPassword({
        email: String(data.get("email")),
        password: String(data.get("password")),
      });
      if (error || !auth.session) {
        if (status)
          status.textContent =
            "Sign-in failed. Check your credentials and moderator access.";
        if (button) button.disabled = false;
        return;
      }
      const response = await fetch("/api/auth/session", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({ access_token: auth.session.access_token }),
      });
      if (!response.ok) {
        await supabase.auth.signOut();
        if (status)
          status.textContent =
            "This account does not have active moderator access.";
        if (button) button.disabled = false;
        return;
      }
      const next = new URLSearchParams(location.search).get("next");
      location.assign(
        next?.startsWith("/") && !next.startsWith("//") ? next : "/moderate/",
      );
    });
  </script>
</BaseLayout>
