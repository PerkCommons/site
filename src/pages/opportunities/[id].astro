---
import { ArrowLeft, ArrowUpRight, CalendarDays, CheckCircle2, Globe2, Tag } from "lucide-astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { categories, formatDate, getListings, statusLabel, type Listing } from "../../lib/listings";
export async function getStaticPaths() { return (await getListings()).map((listing) => ({ params: { id: listing.id }, props: { listing } })); }
const { listing } = Astro.props as { listing: Listing };
---
<BaseLayout title={`${listing.title} — PerkCommons`} description={listing.description}>
  <article class="container py-12" data-pagefind-body>
    <a href="/opportunities/" class="inline-flex items-center gap-2 text-sm text-muted"><ArrowLeft size={16} /> All opportunities</a>
    <div class="mt-9 grid gap-12 lg:grid-cols-[1fr_320px]">
      <div>
        <div class="flex flex-wrap gap-2 text-xs font-medium"><span class="rounded px-2 py-1 status-{listing.status}">{statusLabel(listing.status)}</span><span class="rounded bg-soft px-2 py-1 text-muted">{categories[listing.category]}</span>{listing.sponsor && <span class="rounded border border-line px-2 py-1">Sponsored placement</span>}</div>
        <p class="mt-7 font-medium text-muted" data-pagefind-meta="provider">{listing.provider}</p><h1 class="mt-2 max-w-3xl text-4xl font-semibold leading-tight" data-pagefind-meta="title">{listing.title}</h1><p class="mt-6 max-w-3xl text-lg leading-8 text-muted">{listing.description}</p>
        <section class="mt-10 border-t border-line pt-8"><h2 class="text-xl font-semibold">What you receive</h2><p class="mt-3 leading-7 text-muted">{listing.value}</p></section>
        <section class="mt-8 border-t border-line pt-8"><h2 class="text-xl font-semibold">Eligibility</h2><p class="mt-3 leading-7 text-muted">{listing.eligibility}</p></section>
        {listing.notes && <section class="mt-8 border-t border-line pt-8"><h2 class="text-xl font-semibold">Important notes</h2><p class="mt-3 leading-7 text-muted">{listing.notes}</p></section>}
        <div class="mt-10 flex flex-wrap gap-3"><a href={listing.officialUrl} rel="noopener" class="inline-flex items-center gap-2 rounded-md bg-ink px-5 py-3 font-medium text-white no-underline">Visit official program <ArrowUpRight size={18} /></a><a href={listing.sourceUrl} rel="noopener" class="inline-flex items-center gap-2 rounded-md border border-line bg-white px-5 py-3 font-medium no-underline">Review source <ArrowUpRight size={18} /></a></div>
      </div>
      <aside class="h-fit border-t-2 border-ink bg-white p-6" aria-label="Listing transparency details">
        <h2 class="font-semibold">Transparency</h2><dl class="mt-5 space-y-5 text-sm"><div><dt class="flex items-center gap-2 text-muted"><CheckCircle2 size={16} /> Review</dt><dd class="mt-1.5 font-medium">Source checked {formatDate(listing.reviewDate)}</dd></div><div><dt class="flex items-center gap-2 text-muted"><CalendarDays size={16} /> Status</dt><dd class="mt-1.5 font-medium">{statusLabel(listing.status)}</dd></div><div><dt class="flex items-center gap-2 text-muted"><Globe2 size={16} /> Region</dt><dd class="mt-1.5 font-medium">{listing.regions?.join(", ") ?? "See provider terms"}</dd></div><div><dt class="flex items-center gap-2 text-muted"><Tag size={16} /> Tags</dt><dd class="mt-2 flex flex-wrap gap-1.5">{listing.tags.map((tag) => <span class="rounded bg-soft px-2 py-1">{tag}</span>)}</dd></div></dl><p class="mt-6 border-t border-line pt-5 text-xs leading-5 text-muted">PerkCommons checks published evidence, not outcomes. Eligibility, availability, and terms remain controlled by the provider.</p><a href={`https://github.com/PerkCommons/data/issues/new?title=${encodeURIComponent(`[Correction] ${listing.id}`)}`} class="mt-5 block text-sm">Report a correction</a>
      </aside>
    </div>
  </article>
</BaseLayout>
